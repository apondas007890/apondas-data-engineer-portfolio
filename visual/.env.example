# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional: direct API origin for the visual app when it needs to fetch DB-backed data
# Example: VITE_VISUAL_API_BASE_URL="http://localhost:3001"
VITE_VISUAL_API_BASE_URL=""

# Optional: local dev proxy target for /api requests from the Vite visual app
# Example: VITE_VISUAL_API_PROXY_TARGET="http://localhost:3001"
VITE_VISUAL_API_PROXY_TARGET=""

# Required for the visual contact page Web3Forms submission.
# Put the real key in visual/.env or visual/.env.local, then restart the Vite dev server.
# Example: VITE_WEB3FORMS_ACCESS_KEY="your_web3forms_access_key"
VITE_WEB3FORMS_ACCESS_KEY=""
